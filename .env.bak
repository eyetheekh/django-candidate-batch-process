# Django Core Configuration
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=django-insecure-secret-key-here-django-insecure-secret-key-here-django-insecure-secret-key-here-django-insecure-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,*
CSRF_TRUSTED_ORIGINS=https://dev-internal.pixl.ai,http://localhost,http://127.0.0.1

# Database Configuration (PostgreSQL)
POSTGRES_DB=prod_candidate_batch_process
POSTGRES_USER=postgres
